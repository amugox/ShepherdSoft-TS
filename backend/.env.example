# --- Server ---
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# --- Database (replaces the encrypted Bmat.Tools DbConnData) ---
DATABASE_URL="mysql://shepherd:password@localhost:3306/shepherdsoft"

# --- JWT ---
# JWT_KEY must match ShepherdSoft.Api appsettings JwtToken:Key exactly so
# tokens issued by either stack are interoperable during cutover. Copy the
# live value from the .NET appsettings (or generate a fresh one and update
# both stacks before deploying). Never commit the real secret here.
JWT_ISSUER=https://bmatsolutions.com/
JWT_AUDIENCE=https://bmatsolutions.com/
JWT_KEY=REPLACE_ME_WITH_VALUE_FROM_DOTNET_APPSETTINGS
JWT_SUB=ShepherdSoftBranchUser
JWT_EXPIRES_MIN=30
COOKIE_NAME=shp_jwt
COOKIE_SECURE=false           # set true in production / over HTTPS
COOKIE_SAMESITE=lax           # set to "none" when COOKIE_SECURE=true and the SPA is on a different origin
CSRF_COOKIE_NAME=BS-XSRF-TOKEN

# --- Mail (mirror ShepherdSoft.Api AppSetts:Mail) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_NAME=Bmat Developers
MAIL_FROM=bmatdevs@gmail.com
MAIL_USER=bmatdevs@gmail.com
MAIL_PASS=changeme
MAIL_USE_SSL=true
MAIL_APP_NAME=ShepherdSoft
MAIL_APP_URL=http://localhost:5173
MAIL_SUPPORT_EMAIL=support@bmatsolutions.com

# --- Logging ---
LOG_LEVEL=info
